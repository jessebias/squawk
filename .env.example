# Android local builds (expo run:android) — required on this machine:
# default java is 25, Gradle/RN needs JDK 17
JAVA_HOME=/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home
ANDROID_HOME=$HOME/Library/Android/sdk

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
# MagicBlock (decided in Phase 2 — docs/decisions.md)
EPHEMERAL_RPC_URL=https://devnet-as.magicblock.app/
ROUTER_ENDPOINT=https://devnet-router.magicblock.app/
